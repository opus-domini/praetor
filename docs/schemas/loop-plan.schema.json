{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Praetor Loop Plan",
  "type": "object",
  "required": ["tasks"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string", "minLength": 1 },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" }
          },
          "executor": {
            "type": "string",
            "enum": ["codex", "claude"]
          },
          "reviewer": {
            "type": "string",
            "enum": ["codex", "claude", "none"]
          },
          "model": { "type": "string" },
          "description": { "type": "string" },
          "criteria": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
